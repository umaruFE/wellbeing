    {
      "parameters": {
        "jsCode": "// 提取关键词、人物、风格\nconst item = $input.first()?.json || {};\nconst text = $input.first().json.body.prompt;\nconst type = item.body.type || 'keywords';\n\n// 调用 DashScope 提取\nreturn [{\n  json: {\n    original_text: text,\n    type: type,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "name": "🔍 解析与提取",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        176,
        0
      ],
      "id": "ab4e5bad-0b2a-42ba-ac10-1606dffa2024"
    },
    {
      "parameters": {
        "jsCode": "// 解析提取结果\nconst response = $input.first()?.json || {};\nconst content = response?.output || '{}';\n\ntry {\n  const extracted = JSON.parse(content);\n  // 只返回解析后的数据，不需要 raw\n  return [{ json: extracted }];\n} catch (e) {\n  return [{ json: { background: '', roles: {} } }];\n}"
      },
      "name": "✅ 解析提取结果",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        0
      ],
      "id": "d1169936-51ea-4a3e-90bf-f227dc03476e"
    },
